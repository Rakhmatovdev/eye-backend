PORT=8080
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=Cluster
DB_NAME=intelligence_db
JWT_SECRET=change-me-to-a-random-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-to-a-different-random-secret-min-32-chars
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
ENVIRONMENT=development

# Outbound email (password reset). Leave SMTP_HOST empty to use the no-op
# sender, which just logs that an email would have been sent (fine for local
# dev/tests — the dev-mode response still echoes the raw reset token/link).
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@example.com

# Frontend origin used to build links embedded in emails (e.g. the
# password-reset link: {APP_BASE_URL}/reset-password?token=...).
APP_BASE_URL=http://localhost:3001
